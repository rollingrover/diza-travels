# DIZA TRAVELS — Environment Variables
# Copy this file to .env.local and fill in real values before deploying.

# Currently unused — reserved for when the BookingForm's mailto: fallback
# is replaced with a real API route (see TODO in BookingForm.tsx)
# RESEND_API_KEY=
# BOOKING_NOTIFICATION_EMAIL=safari@dizatravels.co.za

# Google Maps — only needed if swapping the basic iframe embed for the
# JS Maps API (e.g. for a custom-styled interactive map)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
